<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.arkbackend.mapper.UserMapper">

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" resultType="org.example.arkbackend.entity.User">
        select id, username, password, create_time
        from user
        where username = #{username}
    </select>

    <!-- resultType： 把 SQL 查询出来的结果，自动映射成 User 对象-->
    <select id="selectById" resultType="org.example.arkbackend.entity.User">
        select id, username, password, create_time
        from user
        where id = #{id}
    </select>

    <!-- 新增用户 -->
    <insert id="insert">
        insert into user (username, password)
        values (#{username}, #{password})
    </insert>

    <!-- 根据ID更新用户 -->
    <update id="updateByUser">
        update user
        set username = #{username},
            password = #{password}
        where id = #{id}
    </update>

    <!-- 根据ID删除用户 -->
    <delete id="deleteById">
        delete from user
        where id = #{id}
    </delete>

</mapper>